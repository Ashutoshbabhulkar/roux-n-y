# Roux N Y Environment Variables
# Copy this file to '.env' and fill in your API keys.

# Primary Provider: Gemini API (Supports single or multiple comma-separated keys for instant failover rotation)
GEMINI_API_KEY=your_gemini_key_1,your_gemini_key_2

# Failover Backup Provider 1: Groq API Key (Llama 3.3 70B)
GROQ_API_KEY=your_groq_api_key_here

# Failover Backup Provider 2: OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_api_key_here
